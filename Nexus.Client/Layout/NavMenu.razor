@using Microsoft.AspNetCore.Components.Authorization
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject HttpClient Http

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">NEXUS</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-grid-fill" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="projects">
                        <span class="bi bi-briefcase-fill" aria-hidden="true"></span> Projects
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="tickets">
                        <span class="bi bi-ticket-detailed-fill" aria-hidden="true"></span> Tickets
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="team">
                        <span class="bi bi-people-fill" aria-hidden="true"></span> Team
                    </NavLink>
                </div>

                <hr class="text-white-50 mx-3" />

                @* ── NOTIFICATION BELL ── *@
                <div class="nav-item px-3 position-relative" @onclick:stopPropagation>
                    <button class="nav-link btn btn-link text-start w-100 border-0 shadow-none d-flex align-items-center justify-content-between"
                            @onclick="ToggleBell">
                        <span>
                            <span class="bi bi-bell-fill" aria-hidden="true"></span> Notifications
                        </span>
                        @if (unreadCount > 0)
                        {
                            <span class="badge rounded-pill bg-danger" style="font-size:10px;">@unreadCount</span>
                        }
                    </button>

                    @if (isBellOpen)
                    {
                        <div class="notif-dropdown" @onclick:stopPropagation
                             style="left:100%;top:0;right:auto;">
                            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                <span class="fw-bold small text-dark">Notifications</span>
                                <button class="btn btn-link btn-sm text-muted p-0 text-decoration-none"
                                        @onclick="MarkAllRead">
                                    Mark all read
                                </button>
                            </div>
                            @if (!notifications.Any())
                            {
                                <div class="px-3 py-4 text-center text-muted small">
                                    You're all caught up.
                                </div>
                            }
                            @foreach (var n in notifications)
                            {
                                <div class="notif-item @(n.IsRead ? "" : "unread")"
                                     @onclick="() => MarkRead(n.Id)">
                                    <p class="mb-0 small fw-medium text-dark">@n.Message</p>
                                    <span class="text-muted" style="font-size:11px;">
                                        @n.CreatedAt.ToString("MMM d · h:mm tt")
                                    </span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <hr class="text-white-50 mx-3" />

                <div class="nav-item px-3">
                    <button class="nav-link btn btn-link text-start w-100 text-danger border-0 shadow-none"
                            @onclick="HandleLogout">
                        <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Logout
                    </button>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-lock-fill" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    // ── Notifications ──
    private List<NotificationItem> notifications = new();
    private int unreadCount = 0;
    private bool isBellOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadNotifications();
    }

    private async Task LoadNotifications()
    {
        try
        {
            var token = await LocalStorage.GetItemAsStringAsync("authToken");
            if (string.IsNullOrEmpty(token)) return;

            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token.Trim('"'));

            notifications = await Http.GetFromJsonAsync<List<NotificationItem>>("api/Notifications") ?? new();
            unreadCount = notifications.Count(n => !n.IsRead);
        }
        catch { }
    }

    private async Task ToggleBell()
    {
        isBellOpen = !isBellOpen;
        if (isBellOpen) await LoadNotifications();
        StateHasChanged();
    }

    private async Task MarkRead(int id)
    {
        await Http.PatchAsync($"api/Notifications/{id}/read", null);
        await LoadNotifications();
        StateHasChanged();
    }

    private async Task MarkAllRead()
    {
        await Http.PatchAsync("api/Notifications/read-all", null);
        await LoadNotifications();
        StateHasChanged();
    }

    private async Task HandleLogout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        var customAuthStateProvider = (Nexus.Client.Security.CustomAuthStateProvider)AuthStateProvider;
        customAuthStateProvider.MarkUserAsLoggedOut();
        Nav.NavigateTo("login");
    }

    class NotificationItem
    {
        public int Id { get; set; }
        public string Message { get; set; } = "";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}